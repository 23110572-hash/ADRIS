APP_ENV=development
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql+psycopg://user:password@host/adris?sslmode=require
DATABASE_MIGRATION_URL=postgresql+psycopg://user:password@host/adris?sslmode=require
REDIS_URL=rediss://default:password@host:6379/0

GROQ_API_KEY=
GROQ_MODEL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_QUARANTINE_BUCKET=
S3_EVIDENCE_BUCKET=
S3_DERIVATIVES_BUCKET=
S3_EXPORTS_BUCKET=
AWS_KMS_KEY_ID=

JWT_ISSUER=https://your-clerk-domain.clerk.accounts.dev
JWT_AUDIENCE=adris-api
JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
INCIDENT_TOKEN_SECRET=replace_with_at_least_32_random_characters

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
MAX_UPLOAD_BYTES=26214400
PRESIGN_TTL_SECONDS=600
ANONYMOUS_INCIDENTS_ENABLED=true
